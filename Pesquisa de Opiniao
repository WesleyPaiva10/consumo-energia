# Configurações iniciais
limite_teste = 10
limite_total = 50
excelente = 0
ruim = 0

print("--- Pesquisa de Satisfação ---")

# O loop vai até 50 (limite_total)
for i in range(1, limite_total + 1):
    print(f"\nEntrevistado nº {i}:")
    
    nome = input("Digite o nome: ")
    idade = int(input("Digite a idade: "))
    
    print("Opinião: 1-EXCELENTE | 2-BOM | 3-RUIM")
    opiniao = input("Digite sua nota: ")

    if opiniao == "1":
        excelente += 1
    elif opiniao == "3":
        ruim += 1

    # Verificação ao chegar em 10 pessoas
    if i == limite_teste:
        print("\n" + "-"*30)
        continuar = input("Continuar a pesquisa até 50 pessoas? Digite (S) Para exibir o resultador de 10 pessoas digite (N) (S/N): ").upper()
        
        if continuar == "N":
            print("Encerrando pesquisa e gerando relatório parcial...")
            break  # Interrompe o loop for
        else:
            print("Continuando pesquisa...")

# Exibição dos resultados (seja parcial ou total)
print("\n" + "="*30)
print("RESULTADO FINAL DA PESQUISA")
print(f"Total de pessoas entrevistadas: {i}")
print(f"Quantidade de respostas EXCELENTE: {excelente}")
print(f"Quantidade de respostas RUIM: {ruim}")
print("="*30)